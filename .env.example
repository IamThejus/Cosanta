# Copy this file to .env and fill in your keys. .env is git-ignored.

# --- Required credentials ---------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# --- Wake word (OpenWakeWord) -----------------------------------------------
# A pretrained model name (hey_jarvis, alexa, hey_mycroft, hey_rhasspy) OR a
# path to a custom .onnx/.tflite model placed in models/.
COSANTA_WAKEWORD_MODEL=hey_jarvis
# COSANTA_WAKEWORD_MODEL=models/cosanta.onnx
COSANTA_WAKEWORD_THRESHOLD=0.5
# Inference backend: onnx (recommended on ARM64/Termux) or tflite.
COSANTA_WAKEWORD_FRAMEWORK=onnx

# --- Speech-to-text (whisper.cpp) -------------------------------------------
# Path to the whisper.cpp binary (auto-detected from PATH if left as default)
# and a GGML model .bin downloaded into models/ (see README / setup.sh).
COSANTA_WHISPER_BINARY=whisper-cli
COSANTA_WHISPER_MODEL=models/ggml-base.en.bin
COSANTA_WHISPER_LANGUAGE=en
COSANTA_WHISPER_THREADS=4

# --- LLM (Groq REST) --------------------------------------------------------
COSANTA_GROQ_MODEL=llama-3.3-70b-versatile
# COSANTA_GROQ_BASE_URL=https://api.groq.com/openai/v1
# COSANTA_LLM_STREAM=false

# --- Text-to-speech ---------------------------------------------------------
# "android" = phone's built-in TTS via termux-tts-speak (default, no models).
# "piper"   = Piper voice model (set COSANTA_PIPER_VOICE below).
COSANTA_TTS_BACKEND=android
# COSANTA_TTS_LANGUAGE=en-US
# COSANTA_TTS_ENGINE=
# COSANTA_PIPER_VOICE=voices/en_US-lessac-medium.onnx

# --- Logging ----------------------------------------------------------------
COSANTA_LOG_LEVEL=INFO
COSANTA_LOG_TO_FILE=true
