# Copy this file to .env and fill in your keys. .env is git-ignored.

# --- Required credentials ---------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# --- Wake word (OpenWakeWord) -----------------------------------------------
# A pretrained model name (hey_jarvis, alexa, hey_mycroft, hey_rhasspy) OR a
# path to a custom .onnx/.tflite model placed in models/.
COSANTA_WAKEWORD_MODEL=hey_jarvis
# COSANTA_WAKEWORD_MODEL=models/cosanta.onnx
COSANTA_WAKEWORD_THRESHOLD=0.5
# Inference backend: onnx (recommended on ARM64/Termux) or tflite.
COSANTA_WAKEWORD_FRAMEWORK=onnx

# --- Speech-to-text (Faster Whisper) ----------------------------------------
# tiny.en / base.en are recommended on a phone. compute_type=int8 keeps it light.
COSANTA_WHISPER_MODEL=base.en
COSANTA_WHISPER_DEVICE=cpu
COSANTA_WHISPER_COMPUTE_TYPE=int8
COSANTA_WHISPER_LANGUAGE=en

# --- LLM (Groq) -------------------------------------------------------------
COSANTA_GROQ_MODEL=llama-3.3-70b-versatile

# --- Text-to-speech (Piper) -------------------------------------------------
# Download a voice into voices/ and point this at the .onnx file.
COSANTA_PIPER_VOICE=voices/en_US-lessac-medium.onnx

# --- Logging ----------------------------------------------------------------
COSANTA_LOG_LEVEL=INFO
COSANTA_LOG_TO_FILE=true
